+    var menuButton = document.querySelector('.mobile-menu-toggle');
+    var navWrap = document.querySelector('.nav-wrap');
+    var nav = document.getElementById('mainNavigation');
+
+    function setMenu(open) {
+      if (!menuButton || !navWrap) return;
+      menuButton.setAttribute('aria-expanded', open ? 'true' : 'false');
+      menuButton.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
+      navWrap.classList.toggle('is-mobile-open', open);
+    }
+
+    if (menuButton && navWrap) {
+      menuButton.addEventListener('click', function () {
+        setMenu(menuButton.getAttribute('aria-expanded') !== 'true');
+      });
+      if (nav) {
+        nav.addEventListener('click', function (event) {
+          if (event.target.closest('a')) setMenu(false);
+        });
+      }
+      window.addEventListener('resize', function () {
+        if (window.innerWidth > 900) setMenu(false);
+      });
+    }
+
+    var shareButton = document.getElementById('siteShareButton');
+    if (shareButton) {
+      shareButton.addEventListener('click', async function () {
+        var data = { title: document.title, text: document.title, url: window.location.href };
+        try {
+          if (navigator.share) {
+            await navigator.share(data);
+          } else if (navigator.clipboard) {
+            await navigator.clipboard.writeText(window.location.href);
+            var oldLabel = shareButton.getAttribute('aria-label');
+            shareButton.setAttribute('aria-label', 'Link copied');
+            shareButton.title = 'Link copied';
+            setTimeout(function () {
+              shareButton.setAttribute('aria-label', oldLabel || 'Share this page');
+              shareButton.title = 'Share';
+            }, 1400);
+          }
+        } catch (error) {
+          if (error && error.name !== 'AbortError') window.prompt('Copy this link:', window.location.href);
+        }
+      });
+    }
+
